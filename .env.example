# ATLAS platform runtime configuration
# Copy to .env and adjust before deployment:
#   cp .env.example .env

# Web gateway
ATLAS_HOST_PORT=18081

# MinIO object storage
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=changeme
MINIO_DEFAULT_BUCKET=atlas-data
APP_MINIO_SECURE=false
APP_MINIO_PATH_STYLE=true
APP_MINIO_REGION=

# GeoServer
APP_GEOSERVER_USER=admin
APP_GEOSERVER_PASSWORD=geoserver
APP_GEOSERVER_WORKSPACE=atlas
APP_GEOSERVER_PUBLIC_URL=http://localhost:18081/geoserver

# Conversion
APP_DWG2DXF_CMD=dwg2dxf
APP_OGR2OGR_CMD=ogr2ogr
APP_TARGET_SRS=EPSG:4326
APP_GAUSS_KRUGER_ZONE=39
APP_ENABLE_GAUSS_KRUGER_TRANSFORM=true
