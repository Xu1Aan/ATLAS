# Docker deployment defaults. Override as needed for local development.
APP_WORK_DIR=/data
APP_DWG2DXF_CMD=dwg2dxf
APP_OGR2OGR_CMD=ogr2ogr
APP_TARGET_SRS=EPSG:4326
APP_GAUSS_KRUGER_ZONE=39
APP_ENABLE_GAUSS_KRUGER_TRANSFORM=true
APP_GEOSERVER_URL=http://localhost:18081/geoserver
APP_GEOSERVER_USER=admin
APP_GEOSERVER_PASSWORD=geoserver
APP_GEOSERVER_WORKSPACE=dwg
# External URL used by the browser. Change this for production deployment.
APP_GEOSERVER_PUBLIC_URL=http://localhost:18081/geoserver
