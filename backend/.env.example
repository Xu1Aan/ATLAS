# Environment-specific defaults live in:
#   .env.dev  - dev (sw-dev)
#   .env.pro  - pro (sw-pro)
#
# Local development:
#   copy .env.dev .env
#   copy .env.pro .env
#
# Docker build:
#   docker build --build-arg APP_ENV=dev ./backend
#   docker build --build-arg APP_ENV=pro ./backend
#
# Or set APP_ENV=dev|pro when running locally; config.py loads .env.{APP_ENV}
# and optional .env overrides on top.
