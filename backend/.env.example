# Container deployment defaults. Override as needed for local development.
APP_WORK_DIR=/data
APP_DWG2DXF_CMD=dwg2dxf
APP_OGR2OGR_CMD=ogr2ogr
APP_TARGET_SRS=EPSG:4326
APP_GAUSS_KRUGER_ZONE=39
APP_ENABLE_GAUSS_KRUGER_TRANSFORM=true
APP_GEOSERVER_URL=http://10.20.124.71:18081/geoserver
APP_GEOSERVER_USER=admin
APP_GEOSERVER_PASSWORD=geoserver
APP_GEOSERVER_WORKSPACE=dwg
# Browser-facing GeoServer URL. Use a relative gateway path only if your frontend
# is routed through an API gateway.
APP_GEOSERVER_PUBLIC_URL=http://10.20.124.50:30030/public/dwgconvert/geoserver
APP_MINIO_ENDPOINT=http://10.20.124.73:9000
APP_MINIO_ACCESS_KEY=
APP_MINIO_SECRET_KEY=
APP_MINIO_SECURE=false
APP_MINIO_PATH_STYLE=true
APP_MINIO_REGION=
